# PuppyTalk Infra - 환경 변수 예시
# 복사: cp .env.example .env 후 값을 채우세요. .env는 Git에 올라가지 않습니다.

# Docker Compose - PostgreSQL (db 서비스)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=puppytalk

# Backend (2-kyjness-community-be) - DB 연결 (Compose 내부 서비스명 사용)
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_NAME=puppytalk
# 아래 URL은 POSTGRES_* / DB_* 와 실제 비밀번호·DB명이 일치해야 함 (user:pass/dbname 교체)
WRITER_DB_URL=postgresql+psycopg://postgres:your_postgres_password@db:5432/puppytalk
READER_DB_URL=postgresql+psycopg://postgres:your_postgres_password@db:5432/puppytalk

# Backend - Redis (Compose 내부 redis 서비스)
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=20

# Backend - JWT·인증 (배포 시 반드시 변경)
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_SECONDS=1800
REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_TOKEN_COOKIE_NAME=refresh_token
# HTTPS 배포 시 true (Refresh 쿠키 Secure)
COOKIE_SECURE=false
# 프로덕션 권장: openssl rand -hex 32 등. 변경 후에도 기존 유저는 pepper 없이 검증 폴백 가능.
PASSWORD_PEPPER=

# Backend - 서버 (API 공개 기준 URL. 이미지·링크 생성에 사용)
CORS_ORIGINS=https://your-frontend.example,http://127.0.0.1:5173
BE_API_URL=https://api.your-domain.example

# Backend - DEBUG (로컬 Docker: true, 프로덕션: false)
DEBUG=true
TRUST_X_FORWARDED_FOR=true
TRUSTED_HOSTS=your-api-host.example,localhost
REPORT_BLIND_THRESHOLD=5

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Rate limit
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX_REQUESTS=100
LOGIN_RATE_LIMIT_WINDOW=60
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5

# 회원가입 임시 이미지 TTL 정리 주기(초)
SIGNUP_IMAGE_CLEANUP_INTERVAL=3600

# 회원가입 이미지
SIGNUP_IMAGE_TOKEN_TTL_SECONDS=3600
SIGNUP_UPLOAD_RATE_LIMIT_WINDOW=3600
SIGNUP_UPLOAD_RATE_LIMIT_MAX=10

# 파일 업로드 (기본 20MB)
MAX_FILE_SIZE=20971520
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# Backend - 스토리지 (local | s3). s3 시 MinIO/AWS S3 사용
STORAGE_BACKEND=s3
S3_BUCKET_NAME=puppytalk
S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=ap-northeast-2
S3_PUBLIC_BASE_URL=http://localhost:9000/puppytalk

# 로깅
LOG_LEVEL=INFO
LOG_FILE_PATH=
SLOW_REQUEST_MS=1000

# 신고·블라인드 (Phase 2)
REPORT_BLIND_THRESHOLD=5

# HTTPS 배포 시 권장
# HSTS_ENABLED=true

# 조회수 Redis dedup 윈도(초, SET NX EX). 로컬/디버그: 0(매 요청 DB+1). 프로덕션: 3600 등 권장
VIEW_CACHE_TTL_SECONDS=0
# 조회수 Redis 버퍼 → DB flush (초). 미설정 시 config 기본 300 / 120
# VIEW_BUFFER_FLUSH_INTERVAL_SECONDS=300
# VIEW_FLUSH_LOCK_SECONDS=120
